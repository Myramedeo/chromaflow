# .env.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local and keep it in .gitignore.

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Project Dashboard -> Connect -> Direct
# Pooled URL (port 6543) used at runtime
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres?pgbouncer=true"
# Direct URL (port 5432) used for Prisma migrations
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# dashboard.clerk.com -> App -> Configure -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase Realtime ─────────────────────────────────────────────────────────
# Project Dashboard -> Connect -> Framework (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ── Stripe (billing) ──────────────────────────────────────────────────────────
# dashboard.stripe.com -> Developers -> API Keys
# Use test keys (sk_test_...) for local dev, live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Developers -> Webhooks -> Destination -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Products -> Pro product -> Price ID (not Product ID)
STRIPE_PRO_PRICE_ID=price_...

# ── App ───────────────────────────────────────────────────────────────────────
# Used for Stripe redirect URLs, update to your production domain before deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend ────────────────────────────────────────────────────────────────────
# Used for sending emails for task assignments via Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=[sender]@[domain].com

# ── Cron ──────────────────────────────────────────────────────────────────────
CRON_SECRET=[A_RANDOM_SECRET_STRING]